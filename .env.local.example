# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Admin Auth ────────────────────────────────────────────────
ADMIN_JWT_SECRET=your-long-random-secret-min-32-chars
ADMIN_PASSWORD=your-strong-admin-password
ADMIN_EMAIL=your-admin-email@gmail.com

# ── Site URL (used in email links) ───────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app

# ── Razorpay ─────────────────────────────────────────────────
# TEST MODE  → use rzp_test_... keys
# PRODUCTION → use rzp_live_... keys (only after you say go-live)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-test-secret

# ── Twilio (OTP SMS + WhatsApp) ───────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx          # Twilio phone for SMS

# WhatsApp via Twilio Sandbox (for testing):
#   1. Go to console.twilio.com → Messaging → WhatsApp → Sandbox
#   2. Send the join code from your WhatsApp to +14155238886
#   3. Set TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# WhatsApp via Twilio Production:
#   1. Apply for a WhatsApp Business number in Twilio Console
#   2. Set TWILIO_WHATSAPP_FROM=whatsapp:+91xxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Owner Contact ─────────────────────────────────────────────
# 10-digit number without +91 (added automatically)
OWNER_PHONE=9xxxxxxxxx

# ── Email (Gmail App Password) ───────────────────────────────
# Setup:
#   1. Enable 2-Step Verification on your Gmail account
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. Create an App Password for "Mail"
#   4. Paste the 16-character password below (no spaces)
# Install: npm install nodemailer @types/nodemailer
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxxxxxx
